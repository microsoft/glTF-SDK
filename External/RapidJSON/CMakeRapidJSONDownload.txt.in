cmake_minimum_required(VERSION 2.8.2)

project(RapidJSON-download NONE)

include(ExternalProject)
ExternalProject_Add(RapidJSON
  GIT_REPOSITORY    https://github.com/Tencent/rapidjson.git
  GIT_TAG           232389d4f1012dddec4ef84861face2d2ba85709
  SOURCE_DIR        "${CMAKE_BINARY_DIR}/RapidJSON-src"
  BINARY_DIR        "${CMAKE_BINARY_DIR}/RapidJSON-build"
  CMAKE_ARGS        "-DRAPIDJSON_BUILD_DOC=OFF -DRAPIDJSON_BUILD_TESTS=OFF -DRAPIDJSON_BUILD_EXAMPLES=OFF -DRAPIDJSON_BUILD_THIRDPARTY_GTEST=OFF"
  BUILD_COMMAND     ""
  INSTALL_COMMAND   ""
  TEST_COMMAND      ""
)
